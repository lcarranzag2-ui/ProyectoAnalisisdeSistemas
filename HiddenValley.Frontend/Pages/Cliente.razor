
@*   @page "/Cliente"
@using HiddenValley.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h3><i class="bi bi-people-fill"></i> Gestión de Clientes</h3>
        <hr />
        
        <div class="row g-3 mb-3">
            <div class="col-md-8">
                <input @bind="filtro" class="form-control" placeholder="Ingrese DPI o Teléfono..." />
            </div>
            <div class="col-md-4">
                <button @onclick="BuscarCliente" class="btn btn-primary w-100">Buscar</button>
            </div>
        </div>

        @if (cliente != null)
        {
            <div class="alert alert-success d-flex justify-content-between align-items-center">
                <div>
                    <strong>@cliente.NombreCompleto</strong> 
                    <span class="ms-3 text-muted">| DPI: @cliente.DPI</span>
                </div>
                <button @onclick="VerHistorial" class="btn btn-outline-dark btn-sm">Ver Historial</button>
            </div>
        }

        @if (historial != null)
        {
            <table class="table mt-3">
                <thead>
                    <tr><th>ID</th><th>Entrada</th><th>Salida</th><th>Estado</th><th>Total</th></tr>
                </thead>
                <tbody>
                    @foreach (HistorialReservaDTO h in historial)
                    {
                        <tr>
                            <td>@h.Id</td>
                            <td>@h.FechaEntrada.ToShortDateString()</td>
                            <td>@h.FechaSalida.ToShortDateString()</td>
                            <td>@h.Estado</td>
                            <td>Q @h.Total</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private string filtro = "";
    // Cambiado de ClienteResponseDTO a ClienteDetalleDTO para que coincida con tu imagen
    private ClienteDetalleDTO? cliente;
    private List<HistorialReservaDTO>? historial;

    private async Task BuscarCliente() 
    {
        try {
            cliente = await Http.GetFromJsonAsync<ClienteDetalleDTO>($"api/clientes/buscar?filtro={filtro}");
            historial = null;
        } catch { cliente = null; }
    }

    private async Task VerHistorial() 
    {
        if (cliente != null)
        {
            try {
                // Cambiado de .IdCliente a .IdCliente (asegúrate que en el DTO esté igual)
                historial = await Http.GetFromJsonAsync<List<HistorialReservaDTO>>($"api/clientes/{cliente.IdCliente}/historial");
            } catch { historial = new(); }
        }
    }
}
*@